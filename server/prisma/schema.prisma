// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  demoLink    String?
  githubLink  String?
  tags        String
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Profile {
  id            Int      @id @default(autoincrement())
  name          String
  title         String
  bio           String
  heroTitle     String   @default("CREATIVE\nDEVELOPER")
  heroSubtitle  String   @default("Full Stack Web Developer")
  heroDesc      String   @default("SPECIALIZED IN CRAFTING PREMIUM INTERACTIVE WEBSITE SYSTEMS, WEBGL SHADER STRUCTURES, AND FLUID SCROLL GRID ANIMATIONS.")
  aboutTitle    String   @default("A software engineer building premium visual systems for the web.")
  aboutFocus    String   @default("Frontend Architectures & Interactive WebGL")
  aboutLocation String   @default("Kathmandu, Nepal")
  techStack     String   @default("Next.js / React 19:OPTIMAL\nWebGL / GLSL:ADVANCED\nGSAP / Motion Engine:ADVANCED\nTailwind CSS v4:OPTIMAL")
  aboutImageUrl String?
  cvUrl         String?
  email         String?
  github        String?
  linkedin      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
